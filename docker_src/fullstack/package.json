{
  "name": "transcend",
  "version": "1.0.0",
  "description": "Ping Pong Game",
  "main": "dist/server/server.js",
  "scripts": {
    "build:client": "webpack",
    "build:server": "tsc -p tsconfig.server.json",
    "build:css": "tailwindcss -i src/client/css/input.css -o public/css/style.css --minify",
    "build": "npm run build:client && npm run build:server && npm run build:css",
    "dev:client": "webpack --watch",
    "dev:server": "nodemon dist/server/server.js",
    "dev:css": "tailwindcss -i src/client/css/input.css -o public/css/style.css --watch",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:client\" \"npm run build:server -- --watch\" \"npm run dev:server\"",
    "start": "node dist/server/server.js",
    "clean": "rm -rf dist public"
  },
  "dependencies": {
    "@fastify/cors": "^8.0.0",
    "@fastify/static": "^6.10.2",
    "bcrypt": "^5.1.0",
    "fastify": "^4.17.0",
    "sqlite": "^4.2.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^18.16.16",
    "concurrently": "^8.0.1",
    "copy-webpack-plugin": "^11.0.0",
    "nodemon": "^3.1.9",
    "tailwindcss": "^3.3.2",
    "terser-webpack-plugin": "^5.3.9",
    "ts-loader": "^9.4.3",
    "typescript": "^5.0.4",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  }
}
